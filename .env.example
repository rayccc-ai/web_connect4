# 可提交的模板；真实值请放 .env.local（已 gitignore）
# 部署到 Vercel 时，把对应那一个 projectId 填到 Vercel 项目的 Environment Variables。
# 部署域名（origin）由运行时自动取，无需在此配置。

VITE_PID_VALID=<project-id-for-valid-case>
VITE_PID_INVALID=<project-id-for-invalid-case>
VITE_PID_UNKNOWN=<project-id-for-unknown-case>
VITE_PID_SCAM=<project-id-for-scam-case>
